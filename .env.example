# LLM(DeepSeek 或任意 OpenAI 兼容服务)
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat

# 上线体验配额(可选,单位=回合;留空用默认值)
# STORYSIM_PER_IP_DAILY=60       # 每个 IP 每天上限(约 2-3 个完整故事)
# STORYSIM_PER_CLIENT_DAILY=60   # 每个浏览器每天上限
# STORYSIM_GLOBAL_DAILY=2000     # 全站每天总上限(钱包保命)

# 上线防滥用(可选,留空用默认值)
# STORYSIM_CREATE_PER_MIN=20       # 每个 IP 每分钟最多建几个故事(挡刷会话)
# STORYSIM_FEEDBACK_PER_10MIN=10   # 每个 IP 每 10 分钟最多提几次反馈
# STORYSIM_MAX_SESSIONS=500        # 内存里同时存活的会话数上限
# STORYSIM_SESSION_TTL=1800        # 会话闲置多少秒后回收(默认 30 分钟)
# STORYSIM_MAX_BODY_BYTES=65536    # 请求体字节上限(默认 64KB)
