# LLM(DeepSeek 或任意 OpenAI 兼容服务)
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat

# 上线体验配额(可选,单位=回合;留空用默认值)
# STORYSIM_PER_IP_DAILY=60       # 每个 IP 每天上限(约 2-3 个完整故事)
# STORYSIM_PER_CLIENT_DAILY=60   # 每个浏览器每天上限
# STORYSIM_GLOBAL_DAILY=2000     # 全站每天总上限(钱包保命)
